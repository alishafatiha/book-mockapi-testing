  "item": [
    {
      "name": "Validate fetching all books and Validate book structure",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is array\", function () {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Response is not empty\", function () {",
              "    const data = pm.response.json();",
              "    pm.expect(data.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Each book has correct structure\", function () {",
              "    const data = pm.response.json();",
              "",
              "    data.forEach((book, index) => {",
              "        pm.expect(book).to.have.property(\"id\");",
              "        pm.expect(book).to.have.property(\"title\");",
              "        pm.expect(book).to.have.property(\"author\");",
              "        pm.expect(book).to.have.property(\"price\");",
              "",
              "        pm.expect(book.title).to.be.a(\"string\");",
              "        pm.expect(book.author).to.be.a(\"string\");",
              "        pm.expect(book.price).to.be.a(\"string\");",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseurl}}/book",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "book"
          ]
