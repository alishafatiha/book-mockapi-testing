    {
      "name": "Update book by Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code validation\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "",
              "",
              "pm.test(\"Safe JSON validation\", function () {",
              "",
              "    const contentType = pm.response.headers.get(\"Content-Type\") || \"\";",
              "",
              "    // 🔥 cek apakah JSON dulu",
              "    if (contentType.includes(\"application/json\")) {",
              "",
              "        const jsonData = pm.response.json();",
              "        const books = Array.isArray(jsonData) ? jsonData : [jsonData];",
              "",
              "        books.forEach((book, index) => {",
              "",
              "            // required",
              "            pm.expect(book).to.have.property(\"id\");",
              "            pm.expect(book).to.have.property(\"title\");",
              "            pm.expect(book).to.have.property(\"author\");",
              "            pm.expect(book).to.have.property(\"price\");",
              "",
              "            // not empty",
              "            pm.expect(book.title).to.not.eql(\"\");",
              "            pm.expect(book.author).to.not.eql(\"\");",
              "",
              "            // type",
              "            pm.expect(typeof book.id).to.eql(\"string\");",
              "            pm.expect(typeof book.title).to.eql(\"string\");",
              "            pm.expect(typeof book.author).to.eql(\"string\");",
              "            pm.expect(typeof book.price).to.eql(\"number\");",
              "        });",
              "",
              "    } else {",
              "        // 🔥 HANDLE ERROR RESPONSE",
              "        pm.test(\"Response is not JSON (API error)\", function () {",
              "            pm.expect.fail(\"Response is not JSON. Possible server error.\");",
              "        });",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Book\",\n  \"author\": \"Updated Author\",\n  \"price\": 200\n}",
